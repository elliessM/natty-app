{
  "expo": {
    "name": "Natty",
    "slug": "natty-app",
    "version": "2.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "natty",
    "icon": "./assets/logos/logo-beige-on-green.png",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logos/logo-wordmark-lime.png",
      "backgroundColor": "#00412f",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "fr.natty.app",
      "icon": "./assets/logos/logo-beige-on-green.png"
    },
    "android": {
      "package": "fr.natty.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logos/logo-beige-on-green.png",
        "backgroundColor": "#00412f"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#00412f",
          "image": "./assets/logos/logo-wordmark-lime.png",
          "imageWidth": 180,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Natty utilise l'appareil photo pour scanner tes repas et identifier leur composition nutritionnelle."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Natty utilise ta position pour te montrer les frigos connectés les plus proches."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#ed7e00"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ed537da2-9e12-43c3-bec9-c7860c9f4186"
      }
    },
    "owner": "elliessmahir"
  }
}
